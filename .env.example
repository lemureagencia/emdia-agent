# ===== Supabase =====
SUPABASE_URL=https://vwlscymvrtmkuejtkies.supabase.co
# Use a SERVICE ROLE / secret key (sb_secret_...). Fica SÓ aqui no servidor.
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxx

# ===== Transporte do WhatsApp: zernio (oficial) | evolution =====
TRANSPORT=zernio

# ===== Zernio (WhatsApp oficial) =====
ZERNIO_BASE_URL=https://zernio.com/api/v1
ZERNIO_API_KEY=sk_xxxxxxxxxxxx

# ===== Evolution API (legado) =====
EVOLUTION_BASE_URL=https://sua-evolution.com
EVOLUTION_API_KEY=sua_api_key_global
EVOLUTION_INSTANCE=nome_da_instancia

# ===== LLM =====
# provider: rule | groq | openai | gemini | anthropic
LLM_PROVIDER=groq
# Groq: pegue a chave em https://console.groq.com/keys  (gratuito)
LLM_API_KEY=gsk_xxxxxxxxxxxx
# opcional: força o modelo (Groq padrão: llama-3.3-70b-versatile)
LLM_MODEL=llama-3.3-70b-versatile
